# Iris environment overrides — copied to /etc/iris/iris.env on first install.
#
# Values here OVERRIDE the matching keys in /etc/iris/iris.yaml (see
# conf.applyEnv). This is the place for secrets so they stay out of the
# world-readable yaml. Fill these in before `systemctl start iris`.

# --- storage (required) ---
# PostgreSQL/TimescaleDB connection string.
IRIS_DATABASE_DSN=postgres://iris:CHANGE_ME@localhost:5432/iris?sslmode=disable
# Redis address (host:port) and optional password.
IRIS_REDIS_ADDR=localhost:6379
IRIS_REDIS_PASSWORD=

# --- auth (required) ---
# Secret used to sign session tokens. Generate a long random value, e.g.:
#   openssl rand -hex 32
# The service refuses to start without this when dev_bypass is disabled.
IRIS_SESSION_SECRET=CHANGE_ME

# --- first admin (optional; first boot only) ---
# When the user table is empty, these seed an initial owner account so you can
# log in. Ignored once any user exists. After your first login (which will
# prompt MFA enrollment when auth.mfa_required is true), you may remove them.
#IRIS_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
#IRIS_BOOTSTRAP_ADMIN_PASSWORD=change-this-long-password

# --- listeners (optional; defaults from iris.yaml) ---
#IRIS_HTTP_ADDR=:8080
#IRIS_GRPC_ADDR=:9090

# --- logging (optional) ---
#IRIS_LOG_LEVEL=info

# --- development only — DO NOT enable in production ---
# Injects a full-permission identity, bypassing login.
#IRIS_AUTH_DEV_BYPASS=false
