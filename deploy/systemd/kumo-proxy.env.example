# kumo-proxy environment — copy to /etc/kumomta/kumo-proxy.env
#
# The PRIVATE host:port this node's kumo-proxy binds. Must be reachable by the
# other cluster nodes (and iris) over the private network ONLY. Never bind a
# public interface — kumo-proxy is unauthenticated.
#
# Use the node's private cluster IP (this is the ProxyHost:ProxyPort you enter
# for the node on the iris Cluster page).
KUMO_PROXY_LISTEN=10.20.0.12:5000
