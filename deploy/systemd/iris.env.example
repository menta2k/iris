# iris — KumoMTA operator console; environment file for host-native deployment.
#
# Owner: root:iris   Mode: 0640
#   sudo chown root:iris /etc/iris/iris.env
#   sudo chmod 0640 /etc/iris/iris.env
#
# Why a separate file (not the unit itself): secrets stay out of the
# unit so `systemctl cat` is safe to share, and editing the env file
# doesn't require a daemon-reload — `systemctl restart iris`
# is enough.

# ─── kumomta wiring ──────────────────────────────────────────────────
# Where admin-service POSTs admin actions (suspend, resume, bounce,
# queue listings). In the host-native layout kumomta's HTTP listener
# binds to 127.0.0.1:8025 (see IRIS_KUMO_HTTP_LISTEN below) so they
# don't collide with admin-service on :8000.
IRIS_KUMO_API_ENDPOINT=http://127.0.0.1:8025
# Optional bearer token if you've configured kumomta's HTTP listener
# with auth. Leave empty for local-only loopback.
IRIS_KUMO_API_TOKEN=

# Bind spec emitted into kumo.start_http_listener {}. Loopback-only —
# the only consumer is admin-service on the same host.
IRIS_KUMO_HTTP_LISTEN=127.0.0.1:8025

# Filesystem paths shared with the host kumomta daemon. Defaults match
# kumomta's stock Debian/RPM package layout. Permissions: admin-service
# (group `kumomta`) writes; kumomta reads.
IRIS_KUMO_POLICY_DIR=/opt/kumomta/etc/policy
IRIS_DKIM_KEYS_DIR=/opt/kumomta/etc/dkim

# ─── Login firewall: GeoIP (REGION rules) ────────────────────────────
# Path to a MaxMind GeoLite2-Country.mmdb for country-based login rules.
# OPTIONAL: if the file is absent the admin service still boots and
# REGION rules simply fail open (a warning is logged) — IP and TIME rules
# work without it. Requires a free MaxMind license; refresh ~weekly.
IRIS_GEOIP_DB_PATH=/opt/kumomta/etc/GeoLite2-Country.mmdb

# ─── Redis (log stream + suppression index) ──────────────────────────
# Same Redis instance backs both the kumomta log_hook stream and the
# hot-path suppression index — see pkg/spa/handler.go for the
# suppression design rationale.
IRIS_LOGSTREAM_REDIS_URL=redis://127.0.0.1:6379/0
IRIS_LOGSTREAM_NAME=kumo.events
IRIS_LOGSTREAM_GROUP=kumo-ui-tracker
IRIS_LOGSTREAM_WORKERS=4

# ─── JWT secrets ─────────────────────────────────────────────────────
# REQUIRED. The binary refuses to start if these match the placeholder
# values shipped in configs/auth.yaml. Generate:
#   openssl rand -base64 48
IRIS_AUTH_ACCESS_SECRET=
IRIS_AUTH_REFRESH_SECRET=

# ─── Optional ────────────────────────────────────────────────────────
# Override the default mail-class header (X-Kumo-Mail-Class).
#IRIS_MAIL_CLASS_HEADER=X-Mail-Class

# Test-mode MX overrides — JSON object: { "domain": "host:port" }.
# Leave unset in production.
#IRIS_TEST_DOMAIN_ROUTES={"accept.test":"127.0.0.1:2525"}
