# iris — KumoMTA operator console; environment file for host-native deployment.
#
# Owner: root:iris   Mode: 0640
#   sudo chown root:iris /etc/iris/iris.env
#   sudo chmod 0640 /etc/iris/iris.env
#
# Why a separate file (not the unit itself): secrets stay out of the
# unit so `systemctl cat` is safe to share, and editing the env file
# doesn't require a daemon-reload — `systemctl restart iris`
# is enough.

# ─── kumomta wiring ──────────────────────────────────────────────────
# Where admin-service POSTs admin actions (suspend, resume, bounce,
# queue listings). In the host-native layout kumomta's HTTP listener
# binds to 127.0.0.1:8025 (see IRIS_KUMO_HTTP_LISTEN below) so they
# don't collide with admin-service on :8000.
IRIS_KUMO_API_ENDPOINT=http://127.0.0.1:8025
# Optional bearer token if you've configured kumomta's HTTP listener
# with auth. Leave empty for local-only loopback.
IRIS_KUMO_API_TOKEN=

# Bind spec emitted into kumo.start_http_listener {}. Loopback-only —
# the only consumer is admin-service on the same host.
IRIS_KUMO_HTTP_LISTEN=127.0.0.1:8025

# kumomta diagnostic (tracing) log verbosity, emitted into init.lua via
# kumo.set_diagnostic_log_filter. tracing-subscriber EnvFilter syntax.
# Empty uses the iris default (global info + debug on the SMTP server and
# logging subsystems). These lines go to stderr/journald and, with the
# kumomta systemd drop-in, to /var/log/kumomta/diagnostic.log.
#   quieter:  kumod=warn
#   default:  kumod=info,kumod::smtp_server=debug,kumod::logging=debug
#   loud:     kumod=debug
IRIS_KUMO_DIAG_LOG_FILTER=

# Restart kumomta when a policy is applied. KumoMTA loads listeners,
# relay_hosts, spool and the log hook only at process init, so an epoch
# reload cannot apply changes to those — a restart is required. install.sh
# sets this to "sudo systemctl try-restart kumomta.service" and drops a
# scoped sudoers grant (/etc/sudoers.d/iris-kumomta). Leave empty to disable
# (e.g. docker-compose, where you restart the container instead); per-message
# config still hot-reloads via the daemon's epoch poll.
IRIS_KUMO_RESTART_CMD=

# Filesystem paths shared with the host kumomta daemon. Defaults match
# kumomta's stock Debian/RPM package layout. Permissions: admin-service
# (group `kumomta`) writes; kumomta reads.
IRIS_KUMO_POLICY_DIR=/opt/kumomta/etc/policy
IRIS_DKIM_KEYS_DIR=/opt/kumomta/etc/dkim

# ─── Login firewall: GeoIP (REGION rules) ────────────────────────────
# Path to a country .mmdb for country-based login rules. Any MaxMind-DB
# format file with a country.iso_code field works — the free DB-IP
# "IP to Country Lite" db or a MaxMind GeoLite2-Country db.
#
# By default the admin service AUTO-DOWNLOADS the current month's DB-IP
# database to this path on startup (and re-checks daily), so you don't
# have to provision the file yourself. The default lives under
# /var/lib/iris — the unit's StateDirectory=, which is writable under the
# hardened unit (ProtectSystem=strict makes /opt/kumomta/etc read-only, so
# don't point this there). OPTIONAL: with auto-update off and no file the
# service still boots and REGION rules fail open (logged) — IP and TIME
# rules work without any database.
IRIS_GEOIP_DB_PATH=/var/lib/iris/dbip-country-lite.mmdb

# Auto-update controls (all optional):
#   IRIS_GEOIP_AUTO_UPDATE      true (default) | false — disable for air-gapped hosts
#   IRIS_GEOIP_UPDATE_INTERVAL  re-check cadence (default 24h)
#   IRIS_GEOIP_DOWNLOAD_URL     URL template, %s = YYYY-MM (default = DB-IP free)
#IRIS_GEOIP_AUTO_UPDATE=true
#IRIS_GEOIP_UPDATE_INTERVAL=24h

# ─── Redis (log stream + suppression index) ──────────────────────────
# Same Redis instance backs both the kumomta log_hook stream and the
# hot-path suppression index — see pkg/spa/handler.go for the
# suppression design rationale.
IRIS_LOGSTREAM_REDIS_URL=redis://127.0.0.1:6379/0
IRIS_LOGSTREAM_NAME=kumo.events
IRIS_LOGSTREAM_GROUP=kumo-ui-tracker
IRIS_LOGSTREAM_WORKERS=4

# ─── MFA (optional second factor) ────────────────────────────────────
# Self-service TOTP + WebAuthn/passkeys + backup codes. All optional.
#
# IRIS_MFA_SECRET_KEY encrypts TOTP secrets at rest (AES-GCM). Required to
# enable TOTP enrollment; base64 of 16/24/32 random bytes. Generate:
#   openssl rand -base64 32
# Unset → TOTP enrollment is refused (WebAuthn still works); rotating it
# invalidates existing TOTP enrollments.
#IRIS_MFA_SECRET_KEY=
#
# WebAuthn/passkeys: RP ID is the registrable domain; origins are the full
# URLs users hit (comma-separated). Unset → passkeys disabled.
#IRIS_WEBAUTHN_RP_ID=kmx.example.com
#IRIS_WEBAUTHN_RP_DISPLAY_NAME=Iris
#IRIS_WEBAUTHN_RP_ORIGINS=https://kmx.example.com:8443

# ─── JWT secrets ─────────────────────────────────────────────────────
# REQUIRED. The binary refuses to start if these match the placeholder
# values shipped in configs/auth.yaml. Generate:
#   openssl rand -base64 48
IRIS_AUTH_ACCESS_SECRET=
IRIS_AUTH_REFRESH_SECRET=

# ─── Optional ────────────────────────────────────────────────────────
# Override the default mail-class header (X-Kumo-Mail-Class).
#IRIS_MAIL_CLASS_HEADER=X-Mail-Class

# Test-mode MX overrides — JSON object: { "domain": "host:port" }.
# Leave unset in production.
#IRIS_TEST_DOMAIN_ROUTES={"accept.test":"127.0.0.1:2525"}

# ─── Inbound spam filtering (rspamd) ─────────────────────────────────
# No env var — configure mode (off/tag/enforce) + URL in the admin UI
# under Global Settings, then Policy → Apply. rspamd must be reachable
# from the KumoMTA host (e.g. its HTTP worker on 127.0.0.1:11333). Only
# mail received for hosted domains is scanned; fail-open if rspamd is down.
